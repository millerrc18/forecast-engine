# Forecast Engine — Environment Variables
# Copy to .env and fill in values for your deployment.

# Required in production — random 64-char hex string
SECRET_KEY=

# Set to "true" only for local development (bypasses LDAP login)
AUTH_DEV_MODE=false

# Database URL (default: local SQLite)
# DATABASE_URL=sqlite+aiosqlite:///data/forecast.db

# LDAP / Active Directory (required when AUTH_DEV_MODE=false)
LDAP_SERVER=
LDAP_BASE_DN=
LDAP_DOMAIN=

# AD group names for role mapping
AD_GROUP_PM=GRP-FE-PM
AD_GROUP_FUNCMGR=GRP-FE-FUNCMGR
AD_GROUP_LEADERSHIP=GRP-FE-LEADERSHIP
AD_GROUP_ADMIN=GRP-FE-ADMIN

# File paths (optional — defaults are fine for local dev)
# MODEL_DIR=data/models
# UPLOAD_DIR=data/uploads
